<nav class="h-navbar flex bg-bg-sub border-b-2 border-b-main-border">
  <div class="flex grow">
    {{ set index = search.page(`id=index lang=${lang}`) }}
    <a
      class="navbar-tab navbar-brand"
      href="{{ index.url }}"
      title="pluie.me"
    ></a>

    {{ for category of categories }}
      {{ set page = search.page(`id=${category.id} lang=${lang}`) }}
      {{ set matches = it.id == category.id || it.tags.includes(category.tag) }}

      <a
        class='navbar-tab bg-transition text-lg {{ matches && "is-active" }}'
        href="{{ page.url }}"
        title="{{ page.title }}"
      >
        {{ page.title }}
      </a>
    {{ /for }}
  </div>

  <div class="flex items-center gap-4 me-6 text-main-fg-sub text-2xl">
    <button
      id="theme-switcher"
      class="cursor-pointer"
      title="{{ it.navbar.theme_switcher }}"
    >
      <img
        class="split-icon theme scale-90"
        inline
        src="/icons/mdi-theme-light-dark-split.svg"
      />
    </button>
    {{> const counterpart = it.alternates?.find(p => p.lang != lang) }}
    {{ if counterpart?.url }}
      <a
        id="language-switcher"
        href="{{counterpart.url}}"
        title="{{ it.navbar.language_switcher }}"
      >
        <img
          class="split-icon lang scale-90"
          inline
          src="/icons/mdi-translate-split.svg"
        />
      </a>
    {{ else }}
      <div class="i-mdi:translate-off" title="{{ it.navbar.no_translation }}">
      </div>
    {{ /if }}

    <a
      href="{{ it.source }}"
      class="inline-flex text-main-fg-sub hover:text-brand transition-colors duration-150"
      target="_blank"
      title="{{ it.navbar.source }}"
    >
      <img
        src='{{ "git:mono" |> icon("thesvg") }}'
        class="inline-icon place-self-center"
        inline
      >
    </a>
  </div>
</nav>
